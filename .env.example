# ── Go Gateway ──
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRE_MINUTES=10080
# DEV_TOKEN=dev-token-agent        # Debug mode bypass token (optional)
# Keep disabled by default; set DEBUG=true only for local development.
DEBUG=false
PORT=8080

# ── Database ──
DATABASE_DSN=data/agent.db?_journal_mode=WAL&_busy_timeout=5000

# ── Redis (optional) ──
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379

# ── Brave Search ──
# Get your API key at https://api.search.brave.com/app/dashboard
BRAVE_API_KEY=BSA-your-brave-search-api-key

# ── LLM (Python Agent Service) ──
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── Agent Service ──
AGENT_SERVICE_URL=http://localhost:8001
HERMES_SERVICE_URL=http://localhost:8002

# ── Rate Limit ──
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# ── Log ──
LOG_LEVEL=info
LOG_FORMAT=console

# ── Deployment SSH (Paramiko deploy scripts) ──
# Target host is documented here; credentials must be provided locally only.
DEPLOY_HOST=8.215.63.182
DEPLOY_PORT=22
DEPLOY_USER=root

# Choose one authentication method. Do not commit real values.
# DEPLOY_PASS=replace-with-local-password
# DEPLOY_KEY_FILE=C:\Users\you\.ssh\deploy_key

# PARAMIKO_* aliases are also supported for Secret Manager / CI naming.
# PARAMIKO_HOST=8.215.63.182
# PARAMIKO_USERNAME=root
# PARAMIKO_PASSWORD=replace-with-local-password
# PARAMIKO_KEY_FILE=C:\Users\you\.ssh\deploy_key

DEPLOY_TIMEOUT=20
DEPLOY_COMMAND_TIMEOUT=120
# DEPLOY_KNOWN_HOSTS_POLICY=auto_add
