# Hermes Bridge Configuration
# Skills 统一存储目录（所有 skill 安装到此目录）
HERMES_SKILLS_DIR=/home/admin/.hermes/skills

# gstack 仓库路径
GSTACK_HOME=/root/projects/gstack

# Skill Packs 克隆目录（GitHub 导入时临时存放）
SKILL_PACKS_DIR=/root/.agent-platform/skill-packs

# Expert Roles 缓存文件
EXPERT_ROLES_CACHE=/root/.agent-platform/expert_roles.json

# DeepSeek API
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_KEY

# 是否启动时自动加载 gstack（0=禁用）
GSTACK_AUTOLOAD=1

# 服务绑定
HERMES_BIND_HOST=0.0.0.0
HERMES_BIND_PORT=8002

# Agent Service（用于 chat/stream 代理）
AGENT_SERVICE_URL=http://localhost:8001

# 单角色 wallclock 上限（秒）
ORCH_ROLE_TIMEOUT=600

# Run 产物落盘根目录。orchestrator 自动创建子目录
# {AGENT_WORK_DIR}/flow-{flow_id}/run-{run_id}/，Write 工具的文件持久化到这里
AGENT_WORK_DIR=/home/admin/.agent-platform/runs

# Git 配置（GitHub 导入用）
GIT_USER_NAME=mouseqiao85
GIT_USER_EMAIL=mouseqiao@163.com
