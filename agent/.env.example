# ── LLM (Agent Service) ──
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_CUSTOM_HEADER={}
LLM_DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./data/agent_service.db

# ── JWT / Dev Token ──
JWT_SECRET_KEY=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Debug dev token (optional, for Go gateway auth in debug mode)
# GO_DEV_TOKEN=dev-token-agent

# ── Service ──
GO_CALLBACK_URL=http://localhost:8080
HOST=0.0.0.0
PORT=8001
DEBUG=false

# ── Redis (optional) ──
REDIS_URL=redis://localhost:6379/0

# ── Other ──
BRAVE_API_KEY=
SKILLS_DIR=./skills
GENERATED_FILES_DIR=./data/generated
