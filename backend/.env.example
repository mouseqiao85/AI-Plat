# Application
APP_NAME=FinAssistant
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://finassistant:finassistant_dev@localhost:5432/finassistant

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# WeChat
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Brave Search API
BRAVE_API_KEY=your-brave-search-api-key
# Optional: comma-separated IPv4s when local DNS resolves api.search.brave.com incorrectly
BRAVE_API_IPS=

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
FREE_DAILY_CHAT_LIMIT=20

# Data Source Cache TTL (seconds)
CACHE_TTL_QUOTE=30
CACHE_TTL_BASIC=300
CACHE_TTL_FINANCIAL=3600
