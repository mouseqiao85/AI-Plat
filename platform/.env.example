# AI-Plat 平台环境配置示例

# ==================== 项目配置 ====================
PROJECT_NAME=AI-Plat
PROJECT_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==================== 数据库配置 ====================
# PostgreSQL数据库URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_plat

# 异步数据库URL (使用asyncpg)
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_plat

# 开发/测试/生产环境数据库
DEV_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_plat_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_plat_test
PROD_DATABASE_URL=postgresql://postgres:postgres@prod-server:5432/ai_plat

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# SQL日志 (生产环境设为false)
SQL_ECHO=false

# ==================== Redis缓存配置 ====================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Redis连接配置
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# ==================== 认证配置 ====================
# JWT密钥 (生产环境必须修改!)
SECRET_KEY=your-secret-key-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=false

# ==================== OAuth配置 (可选) ====================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ==================== 邮件配置 (可选) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@aiplat.com

# ==================== 大模型配置 ====================
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG_ID=your-org-id

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# 本地模型
OLLAMA_BASE_URL=http://localhost:11434

# ==================== 本体存储配置 ====================
# Apache Jena Fuseki
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=ai_plat

# ==================== 图数据库配置 ====================
# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ==================== 消息队列配置 ====================
# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=ai_plat_group

# ==================== 搜索引擎配置 ====================
# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# ==================== 监控配置 ====================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ==================== CORS配置 ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# ==================== 应用URL配置 ====================
APP_NAME=NexusMind OS - AI-Plat Platform
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==================== 存储路径配置 ====================
DATA_PATH=./data
MODELS_PATH=./models
ONTOLOGY_PATH=./ontology
UPLOAD_PATH=./uploads
LOG_PATH=./logs

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ==================== 速率限制配置 ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15

# ==================== 功能开关 ====================
FEATURE_OAUTH_ENABLED=true
FEATURE_ML_FLOWS_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_CACHE_ENABLED=true
